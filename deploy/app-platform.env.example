DO_VPC_ID=replace-with-default-sfo3-vpc-uuid
DO_GITHUB_REPO=kevinwuhoo/GEOscope
DO_GITHUB_BRANCH=main
ELASTICSEARCH_PASSWORD=copy-from-.env.elasticsearch.production
GEMINI_API_KEY=replace-with-runtime-query-key
# Leave blank while reranking is disabled; set as an App Platform secret to enable.
ANTHROPIC_API_KEY=
GEO_RERANK_ENABLED=false
GEO_RERANK_MODEL=claude-sonnet-5
GEO_RERANK_EFFORT=low
GEO_RERANK_THINKING=disabled
GEO_RERANK_CANDIDATE_LIMIT=40
GEO_RERANK_TIMEOUT_SECONDS=8
GEO_NCBI_TIMEOUT_SECONDS=5
