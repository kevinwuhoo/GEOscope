ELASTICSEARCH_URL=http://10.124.0.2:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=set-in-app-platform
ELASTICSEARCH_ACTIVE_MODEL=gemini_embedding_2_3072_v1
GEMINI_API_KEY=set-in-app-platform
# Required only when GEO_RERANK_ENABLED=true.
ANTHROPIC_API_KEY=
# Start disabled; enable only after recording the baseline-versus-Haiku evaluation.
GEO_RERANK_ENABLED=false
GEO_RERANK_MODEL=claude-haiku-4-5
GEO_RERANK_THINKING=disabled
# Elasticsearch has a floor of 40 candidates and both sources cap at 100.
GEO_RERANK_CANDIDATE_LIMIT=40
GEO_RERANK_TIMEOUT_SECONDS=30
GEO_NCBI_TIMEOUT_SECONDS=5
GEO_MCP_PUBLIC_BASE_URL=https://geoscope.kevinformatics.com
GEO_MCP_ALLOWED_HOSTS=geoscope.kevinformatics.com
GEO_MCP_ALLOWED_ORIGINS=
GEO_MCP_RATE_PER_SECOND=100
GEO_MCP_BURST_CAPACITY=100
GEO_MCP_MAX_CONCURRENT_REQUESTS=20
GEO_LOG_EXPORT_ENABLED=false
GEO_LOG_EXPORT_URL=
